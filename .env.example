# ==========================================================================
# Quant Trading System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==========================================================================

# --- Trading Mode ---
# "paper" = simulated fills (default), "live" = real Coinbase orders
TRADING_MODE=paper

# --- Coinbase API (required for live trading + reconciliation) ---
# Get these from https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Symbols ---
SYMBOLS=btcusd,ethusd,solusd

# --- Database ---
POSTGRES_DB=quantdb
POSTGRES_USER=quant
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://quant:changeme_in_production@timescaledb:5432/quantdb

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Risk Limits ---
MAX_POSITION_SIZE=1.0
MAX_ORDER_NOTIONAL=100000
MAX_DRAWDOWN_PCT=0.05
MAX_TOTAL_EXPOSURE=500000

# --- Service Ports ---
RISK_API_PORT=8090

# --- Alerting ---
# Slack incoming webhook URL for trading alerts (optional)
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- Grafana ---
GRAFANA_PASSWORD=admin

# --- Logging ---
LOG_LEVEL=INFO
