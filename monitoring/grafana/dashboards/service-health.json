{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Up/Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Alpha Engine — Trades Processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(trades_processed{service=\"alpha-engine\"}[1m])",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Alpha Engine — Signals / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(signals_emitted[1m]) * 60",
          "legendFormat": "{{strategy}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Risk Gateway — Approvals vs Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(orders_approved[5m])",
          "legendFormat": "Approved ({{symbol}})"
        },
        {
          "expr": "rate(orders_rejected[5m])",
          "legendFormat": "Rejected ({{symbol}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Risk Gateway — Breaker Blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(signals_breaker_blocked[5m])",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Execution — Fills Per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(fills_total[1m]) * 60",
          "legendFormat": "{{symbol}} {{side}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Execution — Avg Slippage (bps)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(fill_slippage_bps_sum[5m]) / rate(fill_slippage_bps_count[5m])",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "title": "Post-Trade — Messages Processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(fills_processed{service=\"post-trade\"}[1m]) * 60",
          "legendFormat": "Fills/min ({{symbol}})"
        },
        {
          "expr": "rate(trades_processed{service=\"post-trade\"}[1m]) * 60",
          "legendFormat": "Trades/min ({{symbol}})"
        }
      ]
    },
    {
      "title": "Market Data — Publish Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(messages_published[1m]) * 60",
          "legendFormat": "{{type}} msgs/min"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["quant", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Health",
  "uid": "quant-service-health",
  "version": 1
}
