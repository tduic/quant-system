{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Circuit Breaker Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(circuit_breaker_active)",
          "legendFormat": "Breaker"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "ACTIVE", "color": "green" }, "1": { "text": "TRIPPED", "color": "red" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Portfolio Equity",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "portfolio_equity{service=\"post-trade\"}",
          "legendFormat": "Equity"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "title": "Portfolio Drawdown",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "portfolio_drawdown_pct{service=\"post-trade\"}",
          "legendFormat": "Drawdown"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.03 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "title": "Orders Approved / Rejected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(orders_approved[5m]))",
          "legendFormat": "Approved/s"
        },
        {
          "expr": "sum(rate(orders_rejected[5m]))",
          "legendFormat": "Rejected/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Fills Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(fills_total)",
          "legendFormat": "Total Fills"
        }
      ]
    },
    {
      "title": "Total Fees",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "portfolio_total_fees{service=\"post-trade\"}",
          "legendFormat": "Fees"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "title": "Equity Curve",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "portfolio_equity{service=\"post-trade\"}",
          "legendFormat": "Current Equity"
        },
        {
          "expr": "portfolio_peak_equity{service=\"post-trade\"}",
          "legendFormat": "Peak Equity"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "title": "Drawdown Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "portfolio_drawdown_pct{service=\"post-trade\"}",
          "legendFormat": "Drawdown %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "title": "Signals Emitted (by strategy)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(signals_emitted[5m])",
          "legendFormat": "{{strategy}} ({{symbol}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Fill Rate (by symbol)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(fills_total[5m])",
          "legendFormat": "{{symbol}} ({{side}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Fill Slippage (bps) — p50/p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "fill_slippage_bps_sum / fill_slippage_bps_count",
          "legendFormat": "{{symbol}} avg slippage"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "title": "Market Data Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(trades_processed{service=\"alpha-engine\"}[5m])",
          "legendFormat": "{{symbol}} trades/s"
        },
        {
          "expr": "rate(messages_published[5m])",
          "legendFormat": "{{type}} published/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Realized PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "portfolio_realized_pnl{service=\"post-trade\"}",
          "legendFormat": "Realized PnL"
        },
        {
          "expr": "portfolio_unrealized_pnl{service=\"post-trade\"}",
          "legendFormat": "Unrealized PnL"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "Risk Gateway — Rejection Reasons",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum by (reason) (orders_rejected)",
          "legendFormat": "{{reason}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["quant", "trading"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Trading Overview",
  "uid": "quant-trading-overview",
  "version": 1
}
